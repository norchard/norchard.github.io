---
import contacts from "../assets/data/contact.json";
const svgs = import.meta.glob<ImageMetadata>('../assets/contact/*.svg', { query: '?raw', import: 'default', eager: true });
---

<section id="contact" class="module">
    { contacts.map( contact => (
        <a href={ contact.link } target="_blank" class="detail">
            <Fragment set:html={ svgs[`../assets/contact/${ contact.name }.svg`] } />
            <h4>{ contact.title }</h4>
        </a>
    ))}
</section>

<style>
    #contact, .detail {
        display: flex;
        vertical-align: middle;
        align-items: end;
    }

    #contact {
        justify-content: space-between;
    }
    
    .detail {
        align-items: center;
        margin: 10px;
        padding: 8px 12px;
        color: inherit;
        text-decoration: none;
        border-radius: 8px;
        border: 2px solid rgba(0, 0, 0, 0);
        transition: all 0.2s ease-out;
    }

    .detail h4 {
        font-size: 16px;
        line-height: 29px;
        margin: 0px 0px 0px 10px;
        font-weight: 500;
    }

    @media (hover: hover) {
        .detail:hover {
            color: #ffffff;
            background-color: var(--accent);
            /* border: 2px solid var(--module-border); */
        }
    }

    @media (max-width: 700px) {
        #contact {
            display: block;
            vertical-align: middle;
            align-items: end;
        }
        .detail h4 {
            font-size: 18px;
        }
    }
</style>