<style>
    #contact, .detail {
        display: flex;
        vertical-align: middle;
        align-items: end;
    }

    #contact {
        justify-content: space-between;
    }
    
    .detail {
        align-items: center;
        margin: 10px;
        padding: 8px 12px;
        color: inherit;
        text-decoration: none;
        border-radius: 8px;
        border: 2px solid rgba(0, 0, 0, 0);
        transition: all 0.2s ease-out;
    }

    .detail h4 {
        font-size: 16px;
        line-height: 29px;
        margin: 0px;
    }

    .detail:hover {
        color: #ffffff;
        background-color: var(--accent);
        /* border: 2px solid var(--module-border); */
    }

    .detail svg {
        margin-right: 10px;
    }

    @media (max-width: 700px) {
        #contact {
            display: block;
            vertical-align: middle;
            align-items: end;
        }
        .detail h4 {
            font-size: 18px;
        }
    }
</style>