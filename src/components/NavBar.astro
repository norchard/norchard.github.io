---
<section class="container">
    <div id="top-bar">
        <h1 id="name" class="title col-1"><a href="/">Nicole Orchard</a></h1>
        <h1 id="clone" class="title col-1"><a href="/">Nicole Orchard</a></h1>
        <div id='tattoo' class='col-1'>
            <div id='sun'></div>
            <div id='moon'></div>
            <div id='night'></div>
        </div>
    </div>
</section>

<style>
    #top-bar {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        margin: 30px 0px;
        align-items: center;
        --tattoo-size: 40px;
    }
    #name {
        z-index: 10;
    }
    #clone {
        position: absolute;
        margin-bottom: 16px;
        color: var(--accent);
        /* opacity: 0; */
    }
    #tattoo {
        width: fit-content;
        justify-self: flex-end;
        margin-right: 10px;
    }
    /* #name {
        font-size: 24px;
        font-weight: 700;
        padding-left: 10px;
    } */
    .title {
        font-size: 24px;
        font-weight: 700;
        padding-left: 10px;
    }
    .title a {
        color: inherit;
        text-decoration: none;
        font-weight: 600;
    }
    #sun {
        box-sizing: border-box;
        border: solid calc(var(--tattoo-size) / 2) var(--accent);
        height: var(--tattoo-size);
        width: var(--tattoo-size);
        border-radius: calc(var(--tattoo-size) / 2);
        float: right;
        transition: all 0.5s ease;
        cursor: pointer;
    }

    #moon {
        box-sizing: border-box;
        border: solid 4px #d4d4d4;
        height: var(--tattoo-size);
        width: var(--tattoo-size);
        border-radius: calc(var(--tattoo-size) / 2);
        float: right;
        margin-right: calc(0px - calc(var(--tattoo-size) / 2));
        transition: all 0.5s ease;
        cursor: pointer;
    }

    @media (hover: hover) {
        #sun:hover{
            margin-top: -5px;
        }
        #moon:hover{
            margin-top: -5px;
        }
    }

    #night {
        background-color: var(--bg);
        height: calc(var(--tattoo-size) * 1.5);
        width: calc(var(--tattoo-size) * 1.5);
        border-radius: calc(calc(var(--tattoo-size) * 3) / 2);
        float: right;
        margin-right: -25px;
        margin-top: -25px;
        transition: all 0s linear;
        transition-delay: 0s;
        transform: scale(0);
    }
    
    @media (max-width: 700px) {
        .title {
            font-size: 18px;
        }
        #clone {
            margin-bottom: 8px;
        }
        .container:has(#top-bar){
            margin-top: 10px !important;
            padding-top: 0px;
        }
        #top-bar {
            --tattoo-size: 30px;
        }
        #moon {
            border: solid 3px #d4d4d4;
        }
    }
</style>

<script>
    const tattooClick = (e: Event) => {
        e.preventDefault();
        document.body.classList.toggle('dark');
        sessionStorage.setItem('darkmode', document.body.classList.contains('dark').toString());
    }

    document.querySelector('#sun')!.addEventListener('click', tattooClick);
    document.querySelector('#moon')!.addEventListener('click', tattooClick);

    import { gsap } from "gsap";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(SplitText);
    let split1 = SplitText.create("#name a", { type: "chars" });
    let split2 = SplitText.create("#clone a", { type: "chars" });

    const home = document.querySelector('#name > a');


    // 2. Create the animation timeline in a paused state
    const hoverTimeline1 = gsap.timeline({ paused: true });
    const hoverTimeline2 = gsap.timeline({ paused: true });


    // 3. Define the animation tweens
    hoverTimeline1.to(split1.chars, {
        duration: 0.2, 
        y: 10,       // animate from 100px below
        x: 5,
        autoAlpha: 0, // fade in from opacity: 0 and visibility: hidden
        stagger: 0.05, // 0.05 seconds between each
        rotate: 120,
        ease: 'power1.inOut',
    });

    hoverTimeline2.from(split2.chars, {
        duration: 0.2, 
        y: -10,       // animate from 100px below
        x: -5,
        autoAlpha: 0, // fade in from opacity: 0 and visibility: hidden
        stagger: 0.05, // 0.05 seconds between each
        rotate: -120,
        ease: 'power1.inOut',
    });

    if (window.matchMedia && window.matchMedia('(hover: hover)').matches) {
        window.addEventListener('load', () => {
            // Wait a short time before adding the actual mouseover event listener
            setTimeout(() => {
                home?.addEventListener("mouseover", (e) => {
                    hoverTimeline1.play();
                    hoverTimeline2.play();
                });

                home?.addEventListener("mouseleave", (e) => {
                    hoverTimeline1.reverse();
                    hoverTimeline2.reverse();
                });
            }, 100); // 100 milliseconds delay
        });
    }
    
</script>