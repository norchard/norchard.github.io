<style>
    .experience {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        padding: 20px 30px;
        align-items: start;
        max-width: 1200px;
        margin-top: 20px;
    }
    .experience > div {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        width: 100%;
    }
    .experience h3 {
        font-size: 32px;
        margin: 0px;
        font-weight: 400;
    }
    .experience h5 {
        font-size: 16px;
        margin: 0px;
        color: var(--accent);
        font-weight: 600;
    }
    .experience p {
        margin: 0px;
        line-height: 28px;
    }
    .experience a {
        justify-self: end;
        padding: 7px 8px 5px;
        border-radius: 5px;
        transition: all 0.2s ease-out;
    }
    @media (hover: hover) {
        .experience a:hover {
        background-color: var(--accent);
        color: #ffffff;
        }
    }
    @media (max-width: 1050px) {
        .experience > div {
            display: grid;
            grid-template-columns: repeat(1, 1fr);
            width: 100%;
        }
    }

    @media (max-width: 700px) {
        .experience h3 {
            margin-top: 70px;
            font-weight: 700;
        }

        .experience {
            padding: 10px 10px 20px 20px;
        }
    }

    /* #break {
