---
import experiences from "../assets/data/experience.json";
const svgs = import.meta.glob<ImageMetadata>('../assets/companies/*.svg', { query: '?raw', import: 'default', eager: true });

experiences.forEach( (experience, i, array) => {
    array[i] = {
        ...experience,
        "svg": JSON.stringify(svgs[`../assets/companies/${ experience.company }.svg`]),
    }
});

const categories = [...new Set(experiences.map(experience => experience.category))]
---

{ categories.map( category => (
    <div class="container">
        <h4>{ category.charAt(0).toUpperCase() + category.slice(1)}</h4>
        { experiences.filter( exp => exp.category == category ).map( experience => (
            <section class="module experience">
                <div class="col-10">
                    <div class="col-1">
                        <h3>{ experience.title }</h3>
                        <h5>{ experience.date }</h5>
                    </div>
                    <p class="col-1">
                        { experience.description }
                    </p>
                </div>
                <a class="col-2" href={ experience.link } target="_blank">
                    <Fragment set:html={ JSON.parse(experience.svg) } />
                </a>
            </section>
        ))}
    </div>
))}
