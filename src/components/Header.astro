---
import nicoleImage from '../assets/nicole-headshot-square.jpg';
import ContactDetails from './ContactDetails.astro';
---

<section class="container">
    <div id="grid-header" class="fade-in">
        <div id="portrait" class="col-1">
            <img class="slide-up-image" src={nicoleImage.src} alt="Nicole Orchard headshot" fetchpriority="high" />
        </div>
        <div id="greeting" class="col-2">
            <div>
                <h2>Hi, I'm Nicole&nbsp;<span>👋</span></h2>
                <h3>Designer <span>turned</span> Software&nbsp;Engineer</h3>
            </div>
        </div>
        <div id="contact" class="col-2">
            <ContactDetails />
        </div>
    </div>
</section>

<style>
    #grid-header {
        display: grid;
        /* align-items: center; */
        /* vertical-align: text-bottom; */
        /* align-content: space-around; */
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        transition: transform .5s ease-in-out;
        transform: translateX(0px);
        grid-template-areas:
        "a b b"
        "a c c"
        "d d d";
    }

    @keyframes handWave {
        0% { transform: rotate(25deg);}
        20% { transform: rotate(0deg);}
        40% { transform: rotate(25deg);}
        60% { transform: rotate(0deg);}
        80% { transform: rotate(25deg);}
        100% { transform: rotate(0deg);}
    }

    @keyframes slideInLeft {
        0% { opacity: 0; transform: translateX(50px); }
        100% { opacity: 1; transform: translateX(0); }
    }

    @keyframes slideInUp {
        0% { opacity: 0; transform: translateY(50px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    /* Define the animation sequence */
    @keyframes fadeIn {
        0% { opacity: 0; }
        100% { opacity: 1; }
    }

    .fade-in {
        animation: fadeIn 1.5s ease-in-out forwards;
    }

    .slide-in-left {
        animation: slideInLeft 1.5s ease-in-out forwards;
    }

    .slide-in-up {
        animation: slideInUp 1.5s ease-in-out forwards;
    }

    /* Define the animation sequence */
    /* @keyframes slideUpImage {
        0% { transform: scale(120%); }
        100% { transform: scale(100%); }
    } */

    /* .slide-up-image {
        animation: slideUpImage 1.5s ease-in forwards;
    } */
    
    #portrait {
        grid-area: a;
        border-radius: 15px !important;
        overflow: hidden;
        width: 100%;
        box-shadow: 0px 0px 10px var(--module-shadow);
		background-image: linear-gradient(color-mix(in srgb, #ffffff 60%, var(--accent)), var(--accent));
    }
    #portrait img {
        width: 100%;
        height: 100%;
    }
    #greeting {
        margin-left: 20px;
        height: 100%;
        /* display: grid; */
        align-content: center;
        grid-area: b;
        width: 100%;
    }
    #contact {
        grid-area: c; 
        align-content: end;
    }
    #greeting > div > h2 {
        font-size: 64px;
        line-height: 0px;
        padding: 0px 10px;
        font-weight: 400;
        /* font-family: "swear-display", serif; */

        /* padding-top: 20px; */
    }

    #greeting  > div > h2 > span {
        font-size: 45px;
        display: inline-block;
        animation: handWave 4s ease-in-out forwards;
    }

    #greeting  > div > h2 + h3 {
        font-size: 40px;
        line-height: 40px;
        /* padding-bottom: 40px; */
        padding-left: 10px;
        padding-right: 20px;
        font-family: "swear-display", serif;
        font-weight: 400;
        /* color: var(--gray); */
    }

    #greeting  > div > h2 + h3 > span {
        font-style: italic;
        font-weight: 400;
        /* color: var(--accent); */
    }
    @media (max-width: 1050px) {
        #grid-header {
            display: grid;
            /* align-items: center; */
            /* vertical-align: text-bottom; */
            /* align-content: space-around; */
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            grid-template-areas:
            "a b b"
            "d d d";
        }
        #contact {
            /* margin-top: 20px; */
            grid-area: d; 
            align-content: end;
        }
        #greeting {
            grid-area: b; 
        }
    }
    @media (max-width: 900px) {
        #greeting > div > h2 {
            font-size: 50px;
        }

        #greeting  > div > h2 > span {
            font-size: 32px;
        }

        #greeting > div > h2 + h3 {
            font-size: 28px;
            line-height: 28px;
        }
    }
    @media (max-width: 700px) {
        #greeting {
            margin-left: 0px;
        }
        #greeting > div > h2 {
            font-size: 38px;
            line-height: 38px;
            margin: 0px;
            font-weight: 700;
        }

        #greeting  > div > h2 > span {
            font-size: 32px;
        }

        #greeting > div > h2 + h3 {
            font-size: 22px;
            line-height: 26px;
            font-weight: 700;
        }
    }
</style>

